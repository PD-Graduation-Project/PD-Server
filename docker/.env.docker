# ESP32 Factory
FACTORY_SECRET=your-factory-secret-change-in-production

# ML Model Paths (inside worker container)
DRAWING_MODEL_PATH=ml/_FINAL_SCRIPTS/weights/Spiral_Drawing_Model.pth
