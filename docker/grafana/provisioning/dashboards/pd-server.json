{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "API Uptime (up)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "up{job='pd-server'}",
          "legendFormat": "api",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Host CPU Usage %",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))",
          "legendFormat": "cpu",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 3,
      "title": "Host RAM Usage %",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "legendFormat": "ram",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 4,
      "title": "Disk Usage %",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "100 * (1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}))",
          "legendFormat": "disk /",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 5,
      "title": "Load Average (1m)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "targets": [
        {
          "expr": "node_load1",
          "legendFormat": "load1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Network Traffic (bytes/s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_bytes_total{device!~\"lo|veth.*\"}[5m]))",
          "legendFormat": "rx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(node_network_transmit_bytes_total{device!~\"lo|veth.*\"}[5m]))",
          "legendFormat": "tx",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      }
    },
    {
      "id": 7,
      "title": "Application Logs",
      "type": "logs",
      "datasource": "Loki",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "{job=\"pd-server\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": false
      }
    },
    {
      "id": 8,
      "title": "API p95 Latency (ms)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(pd_http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 9,
      "title": "API p99 Latency (ms)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(pd_http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p99",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 10,
      "title": "HTTP Error Rate (%)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "targets": [
        {
          "expr": "100 * sum(rate(pd_http_errors_total[5m])) / clamp_min(sum(rate(pd_http_requests_total[5m])), 0.001)",
          "legendFormat": "error_rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 11,
      "title": "ML Queue Depth",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 34
      },
      "targets": [
        {
          "expr": "pd_ml_queue_depth",
          "legendFormat": "depth",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Oldest Queued Job Age (s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 34
      },
      "targets": [
        {
          "expr": "pd_ml_queue_oldest_seconds",
          "legendFormat": "oldest_age",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 13,
      "title": "ML Throughput (jobs/min)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 34
      },
      "targets": [
        {
          "expr": "rate(pd_ml_completed_total[5m]) * 60",
          "legendFormat": "completed",
          "refId": "A"
        },
        {
          "expr": "rate(pd_ml_failed_total[5m]) * 60",
          "legendFormat": "failed",
          "refId": "B"
        }
      ]
    },
    {
      "id": 14,
      "title": "DB Connections",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 34
      },
      "targets": [
        {
          "expr": "pd_db_connections",
          "legendFormat": "connections",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "title": "API Uptime (%)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 42
      },
      "targets": [
        {
          "expr": "avg_over_time(up{job='pd-server'}[$__range]) * 100",
          "legendFormat": "uptime",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": [
    "pd-server"
