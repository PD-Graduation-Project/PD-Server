# Database
DATABASE_URL=postgresql://pduser:pdpassword@postgres:5432/pdserver

# Redis
REDIS_URL=redis://redis:6379/0

# Flask
SECRET_KEY=your-secret-key-change-in-production
FLASK_ENV=production

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256

# ESP32 Factory
FACTORY_SECRET=your-factory-secret-change-in-production

# ML Model Paths (inside worker container)
DRAWING_MODEL_PATH=ml/_FINAL_SCRIPTS/weights/Spiral_Drawing_Model.pth
TREMOR_MODEL_PATH=ml/_FINAL_SCRIPTS/weights/Tremor_Model.pth
SPEECH_MODEL_PATH=ml/_FINAL_SCRIPTS/weights/Speech_Model.pth

# Storage (MinIO/S3)
STORAGE_BACKEND=s3
MINIO_BUCKET=pd-server
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_SECURE=false

# IP Whitelisting (comma-separated, empty = allow all)
ALLOWED_IPS=

# CORS - comma-separated origins (e.g., "https://app.example.com,https://example.com")
# Leave empty to deny all cross-origin requests
CORS_ORIGINS=

# Gunicorn workers (default 2 for small VMs, increase for larger instances)
GUNICORN_WORKERS=2

# Logging (INFO, DEBUG, WARNING, ERROR; pretty or json)
LOG_LEVEL=INFO
LOG_FORMAT=pretty
# Comma-separated request paths to skip access logging (still counted in metrics)
LOG_SILENT_PATHS=/metrics

# Google Drive weights ID (worker only)
GDRIVE_WEIGHTS_ID=1Svo25SRx7RZ7MW8m1abZerdv7zgypyHT
