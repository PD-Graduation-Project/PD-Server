meta {
  name: Login user
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: inherit
}

body:json {
  {
    "email": "test@mail.com",
    "password": "1234"
  }
}

example {
  name: 200 Response
  description: Login successful
  
  request: {
    url: {{baseUrl}}/api/auth/login
    method: POST
    mode: json
    body:json: {
      {
        "email": "",
        "password": ""
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
          "message": "Login successful",
          "access_token": "your_access_token",
          "refresh_token": "your_refresh_token",
          "token_type": "Bearer",
          "expires_in": 900,
          "user": {
            "id": 1,
            "email": "test@mail.com",
            "created_at": "2023-10-27T10:00:00Z"
          }
        }
      '''
    }
  }
}

example {
  name: 400 Response
  description: Bad request - missing email or password
  
  request: {
    url: {{baseUrl}}/api/auth/login
    method: POST
    mode: json
    body:json: {
      {
        "email": "",
        "password": ""
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: json
      content: '''
        {
          "error": ""
        }
      '''
    }
  }
}

example {
  name: 401 Response
  description: Unauthorized - invalid email or password
  
  request: {
    url: {{baseUrl}}/api/auth/login
    method: POST
    mode: json
    body:json: {
      {
        "email": "",
        "password": ""
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 401
      text: Unauthorized
    }
  
    body: {
      type: json
      content: '''
        {
          "error": ""
        }
      '''
    }
  }
}
