meta {
  name: Get current test
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/api/test/current
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

example {
  name: 200 Response
  description: Current test retrieved successfully
  
  request: {
    url: {{baseUrl}}/api/test/current
    method: GET
    mode: none
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
          "test": {
            "id": 0,
            "user_id": 0,
            "tremor_score": 0,
            "drawing_score": 0,
            "speech_score": 0,
            "pd_probability": 0,
            "created_at": "",
            "completed_at": "",
            "progress": {
              "completed": 0,
              "total": 0,
              "percentage": 0
            },
            "status": ""
          }
        }
      '''
    }
  }
}

example {
  name: 401 Response
  description: Unauthorized - invalid or missing token
  
  request: {
    url: {{baseUrl}}/api/test/current
    method: GET
    mode: none
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 401
      text: Unauthorized
    }
  
    body: {
      type: json
      content: '''
        {
          "error": ""
        }
      '''
    }
  }
}

example {
  name: 404 Response
  description: No current test found
  
  request: {
    url: {{baseUrl}}/api/test/current
    method: GET
    mode: none
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 404
      text: Not Found
    }
  
    body: {
      type: json
      content: '''
        {
          "message": ""
        }
      '''
    }
  }
}
