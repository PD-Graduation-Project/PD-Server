      code: 401
      text: Unauthorized
    }
  
    body: {
      type: json
      content: '''
        {
          "error": ""
        }
      '''
    }
  }
}

example {
  name: 404 Response
  description: Test not found
  
  request: {
    url: {{baseUrl}}/api/test/drawing/submit
    method: POST
    mode: multipartForm
    params:query: {
      ~test_id: 
    }
  
    body:multipart-form: {
      file: 
      test_id: 
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 404
      text: Not Found
    }
  
