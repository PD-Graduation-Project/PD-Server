meta {
  name: Submit drawing test data
  type: http
  seq: 13
}

post {
  url: {{baseUrl}}/api/test/drawing/submit
  body: multipartForm
  auth: bearer
}

params:query {
  ~test_id: 
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  file: 
  test_id: 
}

example {
  name: 200 Response
  description: Drawing test submitted successfully
  
  request: {
    url: {{baseUrl}}/api/test/drawing/submit
    method: POST
    mode: multipartForm
    params:query: {
      ~test_id: 
    }
  
    body:multipart-form: {
      file: 
      test_id: 
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
          "message": "",
          "test_id": 0,
          "drawing_score": 0,
          "ml_results": {
            "score": 0,
            "confidence": 0,
            "frequency_hz": 0,
            "amplitude": 0,
            "regularity": 0,
            "smoothness": 0,
            "tremor_index": 0,
            "spiral_deviation": 0,
            "pitch_variability": 0,
            "voice_stability": 0,
            "articulation": 0
          },
          "test": {
            "id": 0,
            "user_id": 0,
            "tremor_score": 0,
            "drawing_score": 0,
            "speech_score": 0,
            "pd_probability": 0,
            "created_at": "",
            "completed_at": "",
            "progress": {
              "completed": 0,
              "total": 0,
              "percentage": 0
            },
            "status": ""
          }
        }
      '''
    }
  }
}

example {
  name: 400 Response
  description: Bad request - missing test_id or invalid file
  
  request: {
    url: {{baseUrl}}/api/test/drawing/submit
    method: POST
    mode: multipartForm
    params:query: {
      ~test_id: 
    }
  
    body:multipart-form: {
      file: 
      test_id: 
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: json
      content: '''
        {
          "error": ""
        }
      '''
    }
  }
}

