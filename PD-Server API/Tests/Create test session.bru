example {
  name: 201 Created - Tremor Test with Device Override
  description: Successfully created a tremor test with mobile device override

  request: {
    url: {{baseUrl}}/api/tests
    method: POST
    mode: json
    body:json: {
      {
        "test_type": "tremor",
        "device": "mobile",
        "config": {
          "step_1a": true,
          "step_1b": true
        }
      }
    }
  }

  response: {
    headers: {
      Content-Type: application/json
    }

    status: {
      code: 201
      text: Created
    }

    body: {
      type: json
      content: '''
        {
          "success": true,
          "data": {
            "id": 3,
            "user_id": 1,
            "test_type": "tremor",
            "status": "pending",
            "device_source": "mobile",
            "config": {
              "step_1a": true,
              "step_1b": true
            },
            "created_at": "2026-02-09T10:00:00Z",
            "completed_at": null,
            "ml_score": null,
            "inputs": []
          }
        }
      '''
    }
  }
}

example {
  name: 400 Bad Request - Invalid Device
  description: Invalid device value

  request: {
    url: {{baseUrl}}/api/tests
    method: POST
    mode: json
    body:json: {
      {
        "test_type": "tremor",
        "device": "invalid"
      }
    }
  }

  response: {
    headers: {
      Content-Type: application/json
    }

    status: {
      code: 400
      text: Bad Request
    }

    body: {
      type: json
      content: '''
        {
          "success": false,
          "error": "..."
        }
      '''
    }
  }
}

