meta {
  name: Get test session
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/tests/1
  auth: inherit
}

docs {
  # Get Test Session

  Retrieve a specific test session by ID.
}

example {
  name: 200 OK - Completed Test
  description: Successfully retrieved a completed test session

  request: {
    url: {{baseUrl}}/api/tests/1
    method: GET
  }

  response: {
    headers: {
      Content-Type: application/json
    }

    status: {
      code: 200
      text: OK
    }

    body: {
      type: json
      content: '''
        {
          "success": true,
          "data": {
            "id": 1,
            "user_id": 1,
            "test_type": "tremor",
            "status": "completed",
            "device_source": "esp32",
            "config": {
              "step_1a": true,
              "step_1b": true
            },
            "created_at": "2026-02-09T10:00:00Z",
            "completed_at": "2026-02-09T10:00:30Z",
            "ml_score": 0.72,
            "inputs": [
              {
                "id": 1,
                "input_type": "tremor_gyro",
                "file_path": "/uploads/tremor/1/gyro_001.json",
                "mime_type": "application/json",
                "file_size": 1024,
                "created_at": "2026-02-09T10:00:25Z",
                "expires_at": "2026-05-10T10:00:00Z"
              }
            ]
          }
        }
      '''
    }
  }
}

example {
  name: 404 Not Found
  description: Test session does not exist

  request: {
    url: {{baseUrl}}/api/tests/9999
    method: GET
  }

  response: {
    headers: {
      Content-Type: application/json
    }

    status: {
      code: 404
      text: Not Found
    }

    body: {
      type: json
      content: '''
        {
          "error": "Test not found"
        }
      '''
    }
  }
}

example {
  name: 403 Forbidden
  description: Test belongs to another user

  request: {
    url: {{baseUrl}}/api/tests/2
    method: GET
  }

  response: {
    headers: {
      Content-Type: application/json
    }

    status: {
      code: 403
      text: Forbidden
    }

    body: {
      type: json
      content: '''
        {
          "error": "Forbidden"
        }
      '''
    }
  }
}

example {
  name: 401 Unauthorized
  description: Missing authentication token

  request: {
    url: {{baseUrl}}/api/tests/1
    method: GET
  }

  response: {
    headers: {
      Content-Type: application/json
    }

    status: {
      code: 401
      text: Unauthorized
    }

    body: {
      type: json
      content: '''
        {
          "error": "..."
        }
      '''
    }
  }
}
